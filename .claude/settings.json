{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "loto whoami --ensure --json | python3 -c \"import sys,json,os; d=json.load(sys.stdin); print('LOTO_AGENT_ID='+d['id'])\" \u003e\u003e $CLAUDE_ENV 2\u003e/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "loto release --all-mine --json \u003e/dev/null 2\u003e\u00261 || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
